{
  "name": "steamrec",
  "version": "1.0.0",
  "description": "Steam Game Recommendation Website",
  "private": true,
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "npx http-server client -p 8080 -c-1",
    "setup": "npm install && cd server && npm install"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
